<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/navigation/nav_graph.xml -->
<!-- Grafo de navegación principal de AdoptaPet -->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Destino: Pantalla de Inicio -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.adoptapet.app.ui.home.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home">

        <!--
            Acción para navegar al detalle.
            El ID sigue la convención Safe Args:
            "action_{sourceFragment}_to_{destinationFragment}"
            → genera HomeFragmentDirections.actionHomeFragmentToDetailFragment(petId)
        -->
        <action
            android:id="@+id/action_homeFragment_to_detailFragment"
            app:destination="@id/detailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Destino: Detalle de mascota (recibe petId como argumento) -->
    <fragment
        android:id="@+id/detailFragment"
        android:name="com.adoptapet.app.ui.detail.DetailFragment"
        android:label="@string/detail_title"
        tools:layout="@layout/fragment_detail">

        <!-- Argumento Safe Args: ID de la mascota -->
        <argument
            android:name="petId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <!-- Destino: Publicar mascota -->
    <fragment
        android:id="@+id/publishFragment"
        android:name="com.adoptapet.app.ui.publish.PublishFragment"
        android:label="@string/publish_title"
        tools:layout="@layout/fragment_publish" />

    <!-- Destino: Perfil del usuario -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.adoptapet.app.ui.profile.ProfileFragment"
        android:label="@string/profile_title"
        tools:layout="@layout/fragment_profile" />

</navigation>
