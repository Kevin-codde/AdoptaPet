<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/fragment_profile.xml -->
<!-- Pantalla de perfil del usuario autenticado -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header verde con datos del usuario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/primary"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Foto de perfil circular -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@drawable/ic_person"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Circle"
                android:scaleType="centerCrop"
                android:background="@color/primary_light"
                android:padding="16dp"
                app:tint="@color/primary"
                android:contentDescription="Foto de perfil" />

            <!-- Nombre del usuario -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del usuario"
                android:textSize="20sp"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <!-- Email del usuario -->
            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@ejemplo.com"
                android:textSize="14sp"
                android:textColor="@color/primary_light"
                android:layout_marginTop="4dp" />

            <!-- Botón cerrar sesión -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.AdoptaPet.Button.Outline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_logout"
                android:textColor="@color/text_on_primary"
                app:strokeColor="@color/text_on_primary"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- Sección de mascotas publicadas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_pets_label"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <!-- ProgressBar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="16dp" />

            <!-- Estado vacío -->
            <LinearLayout
                android:id="@+id/emptyMyPets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_paw"
                    app:tint="@color/primary_light"
                    android:contentDescription="Sin mascotas" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_my_pets"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="12dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Lista de mascotas propias -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyPets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
