<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/item_my_pet.xml -->
<!-- Tarjeta compacta de mascota para la pantalla de perfil (con botón eliminar) -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.AdoptaPet.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Foto de la mascota (miniatura cuadrada) -->
        <ImageView
            android:id="@+id/ivMyPetPhoto"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_paw_placeholder"
            android:background="@drawable/bg_image_rounded"
            android:clipToOutline="true"
            android:contentDescription="Foto" />

        <!-- Info de la mascota -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvMyPetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMyPetType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="3dp" />

            <TextView
                android:id="@+id/tvMyPetAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Botón eliminar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeletePet"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:strokeColor="@color/error"
            android:textColor="@color/error"
            android:text="@string/btn_delete"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
