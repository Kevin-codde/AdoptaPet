<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/fragment_detail.xml -->
<!-- Pantalla de detalle completo de una mascota -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Foto grande en parte superior -->
        <ImageView
            android:id="@+id/ivDetailPhoto"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_paw_placeholder"
            android:contentDescription="Foto de la mascota" />

        <!-- Contenido de detalle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre + Tipo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="26sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>

            <!-- Edad -->
            <TextView
                android:id="@+id/tvDetailAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                app:drawableStartCompat="@drawable/ic_calendar"
                app:drawableTint="@color/text_secondary"
                android:drawablePadding="6dp" />

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/description_label"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Información de contacto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_info_label"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.AdoptaPet.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/primary_light">

                <TextView
                    android:id="@+id/tvDetailContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Publicado por -->
            <TextView
                android:id="@+id/tvDetailOwner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />

            <!-- Botón Solicitar Adopción -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestAdoption"
                style="@style/Widget.AdoptaPet.Button.Accent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_request_adoption"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
