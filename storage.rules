// storage.rules
// Reglas de seguridad de Firebase Storage para AdoptaPet
// Desplegar con: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Imágenes de mascotas ──────────────────────────────────────────────
    match /pet_images/{imageId} {
      // Leer: cualquier usuario autenticado puede ver imágenes
      allow read: if request.auth != null;

      // Subir: solo usuarios autenticados, archivos de imagen, máx 5MB
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Eliminar: solo usuarios autenticados
      // (la eliminación específica por propietario se controla en el Presenter)
      allow delete: if request.auth != null;
    }

  }
}
